{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*"],
    "rewrites": [
      {
        "source": "/invite/**",
        "destination": "/invite/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options",        "value": "DENY" },
          { "key": "Referrer-Policy",        "value": "no-referrer" }
        ]
      }
    ]
  }
}
