{
  "firestore": {
    "database": "default",
    "rules": "functions/firestore.rules",
    "indexes": "functions/firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "codebase": "default"
  },
  "hosting": {
    "public": "hosting/public",
    "ignore": ["firebase.json", "**/.*"],
    "rewrites": [
      {
        "source": "/invite/**",
        "destination": "/invite/index.html"
      }
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
